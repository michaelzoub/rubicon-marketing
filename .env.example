# Supabase database access for the dashboard.
# These are browser-exposed values; use RLS to enforce creator ownership.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use a publishable key (sb_publishable_...) or the legacy anon JWT.
# Never use sb_secret_... or service_role in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_or_legacy_anon_key

# Privy authentication
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_PUBLIC_PRIVY_CLIENT_ID=your_privy_app_client_id
PRIVY_APP_SECRET=your_privy_app_secret_for_server_verification

# Server-only JWT signing secret from Supabase Project Settings.
# Used by /api/auth/supabase-token to mint short-lived PostgREST bearer JWTs.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
